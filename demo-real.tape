# m1nd REAL demo — live queries against production codebase
# Records the actual demo-real.sh running with real m1nd responses

Output demo-real.gif

Set FontSize 13
Set Width 1200
Set Height 700
Set Theme "Catppuccin Mocha"
Set Padding 15
Set TypingSpeed 20ms
Set PlaybackSpeed 1.5

Sleep 1s
Type "bash demo-real.sh"
Enter
Sleep 90s
